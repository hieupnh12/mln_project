# Frontend local development only.
# Copy to Frontend/.env before running npm.cmd run dev.
# Restart the Vite dev server after changing this file.
#
# Vite proxies /api, /chapters, /lessons and /materials to VITE_BACKEND_URL.
# Feature endpoint constants are relative paths. Do not prefix /api twice.
VITE_API_BASE_URL=/api
VITE_API_WITH_CREDENTIALS=false
VITE_BACKEND_URL=http://localhost:8080
