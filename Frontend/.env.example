# Dev: Vite proxy maps /api → http://localhost:8080/mlnStudy (see vite.config.ts).
# Endpoints in code are relative to this base (e.g. /teacher/...), do not prefix /api twice.
VITE_API_BASE_URL=/api
# Alternative (no proxy): VITE_API_BASE_URL=http://localhost:8080/mlnStudy/api
VITE_API_WITH_CREDENTIALS=false
