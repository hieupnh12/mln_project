# Dev: Vite proxy /mlnStudy → http://localhost:8080 (bỏ prefix /mlnStudy, xem vite.config.ts).
# Google OAuth callback vẫn dùng http://localhost:8080/api/auth/google/callback (đã đăng ký trên Google Console).
VITE_API_BASE_URL=/mlnStudy/api
VITE_API_WITH_CREDENTIALS=false
VITE_BACKEND_URL=http://localhost:8080
