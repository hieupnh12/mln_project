# Root local environment file.
# Copy this file to .env when running the backend directly or using Docker Compose.
# Never put VITE_* variables in Frontend/.env if they contain secrets: VITE_* values are public.

# Database reachable by the backend process or backend container.
MYSQL_HOST=your_mysql_host
MYSQL_PORT=3306
MYSQL_DATABASE=mln_database
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_SSL_MODE=REQUIRED

# Google OAuth backend credentials.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# Docker host ports.
BACKEND_PORT=8080
FRONTEND_PORT=3000

# Backend runtime settings.
# Leave FRONTEND_BASE_URL unset for the local defaults:
# - direct backend + Vite dev server: http://localhost:5173
# - Docker Compose: http://localhost:3000
# FRONTEND_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*
APP_SECURITY_ENABLED=false
JWT_SIGNER_KEY=replace_with_a_secret_key_at_least_32_characters_long
ADMIN_EMAIL=admin@example.com

# Optional integrations.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# LIBREOFFICE_PATH=C:/Program Files/LibreOffice/program/soffice.exe

# Docker frontend build variables.
# These values are embedded into the browser bundle during docker compose build.
VITE_API_BASE_URL=http://localhost:8080/api
VITE_API_WITH_CREDENTIALS=false
